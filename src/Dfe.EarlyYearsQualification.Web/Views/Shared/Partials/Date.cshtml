@model Dfe.EarlyYearsQualification.Web.Models.Content.QuestionModels.DateQuestionModel

<div class="govuk-form-group @(Model.HasError ? "govuk-form-group--error" : "")">
    @if (Model.DisplayHeader)
    {
        <h2 class="govuk-heading-s" id="@Model.Prefix-header">@Model.QuestionHeader</h2>
    }

    @if (Model.DisplayHint)
    {
        <div id="@Model.Prefix-hint" class="govuk-hint">@Model.QuestionHint</div>
    }

    @if (Model.HasError)
    {
        <govuk-error-message id="@Model.Prefix-error" visually-hidden-text="Error">@Html.Raw(Model.ErrorMessage)</govuk-error-message>
    }

    <div class="govuk-date-input" id="@Model.QuestionId">
        <div class="govuk-date-input__item">
            <div class="govuk-form-group">
                <label id="@Model.Prefix-month-label" class="govuk-label govuk-date-input__label" for="@Model.MonthId">@Model.MonthLabel</label>
                @Html.TextBox(Model.MonthId, Model.SelectedMonth, new { id = Model.MonthId, @class=Model.MonthClass, maxlength=2, name=Model.MonthId, type="text", inputmode="numeric", autocomplete="off", aria_describedby=Model.AriaDescribedBy })
            </div>
        </div>
        <div class="govuk-date-input__item">
            <div class="govuk-form-group">
                <label id="@Model.Prefix-year-label" class="govuk-label govuk-date-input__label" for="@Model.YearId">@Model.YearLabel</label>
                @Html.TextBox(Model.YearId, Model.SelectedYear, new { id = Model.YearId, @class=Model.YearClass, maxlength=4, name=Model.YearId, type="text", inputmode="numeric", autocomplete="off", aria_describedby=Model.AriaDescribedBy })
            </div>
        </div>
    </div>
</div>
